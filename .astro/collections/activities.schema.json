{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 2
    },
    "description": {
      "type": "string",
      "minLength": 10
    },
    "link": {
      "type": "string"
    },
    "color": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}$"
    },
    "order": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9007199254740991
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "ongoing",
        "upcoming",
        "completed"
      ]
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "color",
    "order",
    "status"
  ]
}