---
interface DonateSectionContent {
  eyebrow: string;
  heading: string;
  body: string;
  cta_text: string;
  uses_header: string;
  uses_items: string[];
}

interface Props {
  paystackUrl: string;
  donate: DonateSectionContent;
}

const { paystackUrl, donate } = Astro.props;
---

<section class="donate-section" id="donate">
  <div class="container">
    <div class="donate-inner">

      <div class="donate-copy">
        <span class="eyebrow">{donate.eyebrow}</span>
        <h2 class="heading-serif donate-heading">
          {donate.heading}
        </h2>
        <p class="donate-body">
          {donate.body}
        </p>
        <a href={paystackUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
          {donate.cta_text}
        </a>
      </div>

      <div class="donate-uses card">
        <div class="donate-uses-header">{donate.uses_header}</div>
        <ul class="donate-list">
          {donate.uses_items.map((item, i) => (
            <li><span class="donate-num">{String(i + 1).padStart(2, '0')}</span>{item}</li>
          ))}
        </ul>
      </div>

    </div>
  </div>
</section>

<style>
  .donate-section {
    padding-block: var(--section);
    background: var(--yellow);
    border-top: 2px solid var(--black);
    border-bottom: 2px solid var(--black);
  }

  .donate-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s8);
  }
  @media (min-width: 860px) {
    .donate-inner {
      grid-template-columns: 1fr 1fr;
      align-items: start;
      gap: var(--s10);
    }
  }

  .donate-copy {
    display: flex;
    flex-direction: column;
    gap: var(--s5);
  }

  .donate-heading {
    font-size: clamp(var(--text-3xl), 5vw, var(--text-4xl));
    line-height: var(--leading-tight);
  }

  .donate-body {
    font-size: var(--text-base);
    color: var(--text-mid);
    line-height: var(--leading-body);
    max-width: 420px;
  }

  .donate-uses {
    overflow: hidden;
  }

  .donate-uses-header {
    padding: var(--s4) var(--s5);
    background: var(--black);
    color: var(--yellow);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .donate-list {
    display: flex;
    flex-direction: column;
  }

  .donate-list li {
    display: flex;
    align-items: center;
    gap: var(--s4);
    padding: var(--s4) var(--s5);
    border-bottom: 2px solid var(--black);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text);
    background: var(--bg-white);
    transition: background 150ms ease;
  }
  .donate-list li:last-child { border-bottom: none; }
  .donate-list li:hover { background: var(--pink-light); }

  .donate-num {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    color: var(--pink);
    flex-shrink: 0;
    line-height: 1;
  }
</style>
