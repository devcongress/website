---
interface Social { platform: string; url: string; }
interface Props { socials: Social[]; }
const { socials } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-body">

    <div class="footer-brand">
      <a href="/" aria-label="DevCongress home">
        <img src="/website/images/logo.png" alt="dev:congress{};" height="36" />
      </a>
      <p class="footer-tagline">Africa's home for builders.</p>
      <a href="mailto:hello@devcongress.org" class="footer-email">
        hello@devcongress.org
      </a>
    </div>

    <nav class="footer-nav" aria-label="Footer links">
      <p class="footer-nav-label">Links</p>
      <ul>
        <li><a href="#community">Community</a></li>
        <li><a href="#programs">Programs</a></li>
        <li><a href="#meetups">Meetups</a></li>
        <li><a href="#admins">Admins</a></li>
        <li><a href="#partners">Partners</a></li>
        <li><a href="#donate">Support Us</a></li>
        <li><a href="/website/coc/">Code of Conduct</a></li>
      </ul>
    </nav>

    <div class="footer-social">
      <p class="footer-nav-label">Find us</p>
      <ul>
        {socials.map((s) => (
          <li>
            <a href={s.url} target="_blank" rel="noopener noreferrer" class="footer-social-link">
              {s.platform}
            </a>
          </li>
        ))}
      </ul>
    </div>

  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <span>&copy; {year} DevCongress. Built by the community, for the community.</span>
      <a href="/website/coc/">Code of Conduct</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 2px solid var(--black);
    background: var(--black);
    color: #f0f0f0;
  }

  .footer-body {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s8);
    padding-block: var(--s9);
  }
  @media (min-width: 720px) {
    .footer-body { grid-template-columns: 2fr 1fr 1fr; }
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: var(--s4);
  }

  /* Logo has its own yellow background — renders well on dark */
  .footer-brand img { border-radius: 4px; }

  .footer-tagline {
    font-size: var(--text-sm);
    color: #888;
  }

  .footer-email {
    font-size: var(--text-sm);
    color: #888;
    transition: color 150ms ease;
  }
  .footer-email:hover { color: var(--yellow); }

  .footer-nav-label {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--yellow);
    margin-bottom: var(--s4);
  }

  .footer-nav ul,
  .footer-social ul {
    display: flex;
    flex-direction: column;
    gap: var(--s3);
  }

  .footer-nav a {
    font-size: var(--text-sm);
    color: #888;
    transition: color 150ms ease;
    text-transform: capitalize;
  }
  .footer-nav a:hover { color: #f0f0f0; }

  .footer-social-link {
    font-size: var(--text-sm);
    color: #888;
    text-transform: capitalize;
    transition: color 150ms ease;
  }
  .footer-social-link:hover { color: var(--yellow); }

  .footer-bottom {
    border-top: 1px solid #222;
    padding-block: var(--s4);
  }

  .footer-bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--s3);
    font-size: var(--text-xs);
    color: #555;
  }

  .footer-bottom-inner a {
    color: #555;
    transition: color 150ms ease;
  }
  .footer-bottom-inner a:hover { color: var(--yellow); }
</style>
