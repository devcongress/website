---
interface Props {
  slackUrl: string;
  paystackUrl: string;
  youtubeEmbedUrl: string;
}
const { slackUrl, paystackUrl, youtubeEmbedUrl } = Astro.props;
---

<section class="hero" id="hero">
  <div class="container">

    <div class="hero-top">
      <span class="eyebrow">Africa's tech community</span>
      <h1 class="heading-serif hero-headline">
        Where Africa's builders<br />
        connect, collaborate<br />
        and grow.
      </h1>
      <div class="hero-ctas">
        <a href={slackUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-hero">
          Join on Slack
        </a>
        <a href={paystackUrl} target="_blank" rel="noopener noreferrer" class="btn btn-outline btn-hero">
          Support the mission
        </a>
      </div>
    </div>

  </div>

  <!-- Full-width video — breaks out of container -->
  <div class="hero-video-wrap">
    <div class="hero-video-bar">
      <span class="hero-video-label">dev:congress&#123;&#125;; — community highlight</span>
      <span class="hero-video-live">● Live community</span>
    </div>
    <div class="hero-video">
      <iframe
        src={youtubeEmbedUrl}
        title="DevCongress — Community Highlight"
        loading="lazy"
        referrerpolicy="strict-origin-when-cross-origin"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen
      ></iframe>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: clamp(3rem, 6vw, 5rem);
    padding-bottom: 0;
  }

  .hero-top {
    max-width: 900px;
    margin-inline: auto;
    margin-bottom: var(--s9);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-headline {
    font-size: clamp(var(--text-3xl), 7vw, var(--text-5xl));
    margin-bottom: var(--s7);
    letter-spacing: -0.01em;
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s4);
    justify-content: center;
  }

  .btn-hero {
    padding: var(--s4) var(--s8);
    font-size: var(--text-base);
  }

  /* Video — full width, breaks container */
  .hero-video-wrap {
    border-top: 2px solid var(--black);
  }

  .hero-video-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--s3) var(--pad);
    background: var(--yellow);
    border-bottom: 2px solid var(--black);
  }

  .hero-video-label {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--black);
    font-family: var(--font-body);
  }

  .hero-video-live {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--pink);
    letter-spacing: 0.06em;
  }

  .hero-video iframe {
    width: 100%;
    aspect-ratio: 16 / 9;
    border: none;
    display: block;
  }
</style>
