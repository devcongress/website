---
interface Partner {
  id: string;
  data: { name: string; logo: string; url?: string; backgroundColor?: string; };
}
interface Props { partners: Partner[]; }
const { partners } = Astro.props;
const sortedPartners = [...partners].sort((a, b) => a.data.name.localeCompare(b.data.name));
---

<section class="section" id="partners">
  <div class="container">
    <span class="eyebrow">Partners</span>
    <h2 class="heading-serif partners-heading">Built with support</h2>

    <ul class="partner-row">
      {sortedPartners.map((p) => (
        <li class="partner-item">
          {p.data.url
            ? <a href={p.data.url} target="_blank" rel="noopener noreferrer" aria-label={p.data.name}>
                <img
                  src={p.data.logo}
                  alt={p.data.name}
                  loading="lazy"
                  class={p.data.backgroundColor ? 'has-bg' : ''}
                  style={p.data.backgroundColor ? 'background-color:' + p.data.backgroundColor : ''}
                />
              </a>
            : <img
                src={p.data.logo}
                alt={p.data.name}
                loading="lazy"
                class={p.data.backgroundColor ? 'has-bg' : ''}
                style={p.data.backgroundColor ? 'background-color:' + p.data.backgroundColor : ''}
              />
          }
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .partners-heading {
    font-size: clamp(var(--text-3xl), 5vw, var(--text-4xl));
    margin-bottom: var(--s8);
  }

  .partner-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: flex-start;
    column-gap: clamp(12px, 3vw, 24px);
    row-gap: clamp(12px, 3vw, 24px);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .partner-item { flex: 0 1 auto; }

  .partner-item a,
  .partner-item img {
    display: block;
  }

  .partner-item img {
    max-height: 100px;
    max-width: 100%;
    height: auto;
    width: auto;
    object-fit: contain;
  }

  .partner-item img.has-bg {
    padding: clamp(8px, 2vw, 20px);
    border-radius: var(--r-md);
  }
</style>
