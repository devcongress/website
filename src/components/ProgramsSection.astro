---
interface Activity {
  id: string;
  data: {
    title: string;
    description: string;
    link: string;
    color: string;
    order: number;
    status: 'active' | 'ongoing' | 'upcoming';
  };
}
interface Props { activities: Activity[]; }
const { activities } = Astro.props;
const sorted = [...activities].sort((a, b) => a.data.order - b.data.order);

const statusLabel: Record<string, string> = {
  active:   'Active',
  ongoing:  'Ongoing',
  upcoming: 'Upcoming',
};
---

<section class="section" id="programs">
  <div class="container">
    <p class="section-label">Programs</p>
    <h2 class="section-heading programs-heading">What we do</h2>

    <ul class="programs-grid">
      {sorted.map((activity) => (
        <li class="program-card">
          <div class="program-card-top">
            <span
              class={`badge badge-${activity.data.status}`}
            >{statusLabel[activity.data.status]}</span>
            <div
              class="program-dot"
              style={`background: ${activity.data.color};`}
              aria-hidden="true"
            ></div>
          </div>
          <h3 class="program-title">
            <a href={activity.data.link}>{activity.data.title}</a>
          </h3>
          <p class="program-desc">{activity.data.description}</p>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .programs-heading { margin-bottom: var(--space-7); }

  .programs-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .programs-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (min-width: 1024px) {
    .programs-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .program-card {
    background: var(--color-bg-raised);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    transition: border-color 200ms ease, background 200ms ease;
  }

  .program-card:hover {
    border-color: var(--color-text-faint);
    background: var(--color-bg-subtle);
  }

  .program-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .program-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .program-title {
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-text);
    line-height: var(--leading-snug);
  }

  .program-title a:hover { color: var(--color-accent); }

  .program-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-body);
    flex: 1;
  }
</style>
