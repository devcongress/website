---
interface Stats { members: string; hired: string; events: string; mentored: string; }
interface Props { stats: Stats; }
const { stats } = Astro.props;

const items = [
  { value: stats.members,  label: 'Community members' },
  { value: stats.hired,    label: 'Members hired'     },
  { value: stats.events,   label: 'Events run'        },
  { value: stats.mentored, label: 'Mentored'          },
];
---

<div class="stats-bar">
  <div class="container stats-inner">
    {items.map((item, i) => (
      <>
        <div class="stat">
          <span class="stat-value">{item.value}</span>
          <span class="stat-label">{item.label}</span>
        </div>
        {i < items.length - 1 && <div class="stat-divider" aria-hidden="true"></div>}
      </>
    ))}
  </div>
</div>

<style>
  .stats-bar {
    border-top: 2px solid var(--black);
    border-bottom: 2px solid var(--black);
    background: var(--bg-white);
    padding-block: var(--s7);
  }

  .stats-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--s5);
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--s2);
    flex: 1;
    min-width: 120px;
    text-align: center;
  }

  .stat-value {
    font-family: var(--font-serif);
    font-size: clamp(var(--text-3xl), 5vw, var(--text-4xl));
    line-height: 1;
    color: var(--pink);
    letter-spacing: -0.01em;
  }

  .stat-label {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-muted);
    letter-spacing: 0.02em;
  }

  .stat-divider {
    width: 2px;
    height: 48px;
    background: var(--border-light);
    flex-shrink: 0;
  }

  @media (max-width: 600px) {
    .stats-inner { justify-content: center; }
    .stat-divider { display: none; }
    .stat { min-width: calc(50% - var(--s5)); }
  }
</style>
