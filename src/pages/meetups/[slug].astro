---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const meetups = await getCollection('meetups');
  return meetups.map((meetup) => {
    const slug = meetup.id.replace(/\/meta$/, '');
    return { params: { slug }, props: { meetup } };
  });
}

const { meetup } = Astro.props;
const { name, date, location, description, cover, photos } = meetup.data;

function formatDate(iso: string): string {
  const [y, mo, d] = iso.split('-').map(Number);
  return new Date(y, mo - 1, d).toLocaleDateString('en-GB', {
    day: 'numeric', month: 'long', year: 'numeric',
  });
}
---

<Base title={`${name} — DevCongress`} description={description}>
  <header class="mnav">
    <div class="container mnav-inner">
      <a href="/" class="mnav-logo">
        <img src="/website/images/logo.png" alt="DevCongress" height="36" />
      </a>
      <a href="/#meetups" class="mnav-back">← All meetups</a>
    </div>
  </header>

  <main>
    <!-- Hero image -->
    <div class="meetup-hero" style={`background-image: url('${cover}')`} role="img" aria-label={`${name} cover photo`}></div>

    <!-- Header info below image -->
    <div class="meetup-intro">
      <div class="container">
        <div class="meetup-meta">
          <time datetime={date} class="meetup-date">{formatDate(date)}</time>
          <span class="meetup-location">{location}</span>
        </div>
        <h1 class="heading-serif meetup-title">{name}</h1>
        <p class="meetup-desc">{description}</p>
      </div>
    </div>

    <!-- Gallery -->
    {photos.length > 0 && (
      <div class="gallery-section">
        <div class="container">
          <div class="gallery-header">
            <span class="eyebrow">Gallery</span>
            <span class="gallery-count">{photos.length} photos</span>
          </div>
          <ul class="gallery-grid">
            {photos.map((photo, i) => (
              <li class="gallery-item">
                <img
                  src={photo}
                  alt={`${name} — photo ${i + 1}`}
                  loading="lazy"
                  decoding="async"
                />
              </li>
            ))}
          </ul>
        </div>
      </div>
    )}
  </main>
</Base>

<style>
  .mnav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--bg);
    border-bottom: 2px solid var(--black);
    padding-block: var(--s4);
  }
  .mnav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .mnav-back {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-mid);
    transition: color 150ms ease;
  }
  .mnav-back:hover { color: var(--pink); }

  .meetup-hero {
    width: 100%;
    aspect-ratio: 21 / 9;
    background-size: cover;
    background-position: center;
    background-color: var(--border-light);
    border-bottom: 2px solid var(--black);
  }
  @media (max-width: 640px) { .meetup-hero { aspect-ratio: 16 / 9; } }

  .meetup-intro {
    padding-block: var(--s8);
    border-bottom: 2px solid var(--black);
    background: var(--bg-white);
  }

  .meetup-meta {
    display: flex;
    align-items: center;
    gap: var(--s4);
    margin-bottom: var(--s4);
  }

  .meetup-date {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text-muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .meetup-location {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--pink);
    background: var(--pink-light);
    border: 1.5px solid var(--pink);
    border-radius: var(--r-full);
    padding: 2px var(--s3);
  }

  .meetup-title {
    font-size: clamp(var(--text-3xl), 6vw, var(--text-4xl));
    margin-bottom: var(--s4);
  }

  .meetup-desc {
    font-size: var(--text-lg);
    color: var(--text-mid);
    line-height: var(--leading-body);
    max-width: 680px;
  }

  .gallery-section { padding-block: var(--s9); }

  .gallery-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--s6);
  }

  .gallery-count {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text-muted);
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--s3);
    border: 2px solid var(--black);
    border-radius: var(--r-md);
    overflow: hidden;
  }
  @media (min-width: 640px)  { .gallery-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 1024px) { .gallery-grid { grid-template-columns: repeat(4, 1fr); } }

  .gallery-item {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--border-light);
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 400ms ease, filter 300ms ease;
    filter: grayscale(0.1);
  }
  .gallery-item:hover img {
    transform: scale(1.06);
    filter: grayscale(0);
  }
</style>
